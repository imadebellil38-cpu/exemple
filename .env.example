# ── ProspectHunter — Environment Variables ──
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000

# JWT Authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Google Places API
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Rate Limiting (15 min window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SEARCH_RATE_LIMIT_MAX=10

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=https://empire-leads.fr,https://www.empire-leads.fr

# PostgreSQL SSL (set to 'false' to disable certificate verification, e.g. for self-signed certs)
DB_SSL_REJECT_UNAUTHORIZED=false
